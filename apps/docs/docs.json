              "servers/viettel-pay"
            ]
          }
        ]
      },
      {
        "dropdown": "Blog",
        "icon": "pen-nib",
        "description": "Announcements, guides, and tutorials",
        "groups": [
          {
            "group": "Posts",
            "pages": [
              "blog/introducing-vn-mcp-hub",
              "blog/guide-momo-payments",
              "blog/guide-zalopay-integration",
              "blog/guide-vnpay-gateway",
              "blog/guide-zalo-oa-messaging",
              "blog/guide-viettelpay"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/nguyenduchuy27111997-creator/vietnamese-mcp"
